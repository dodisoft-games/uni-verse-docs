        {
            "id": "block-005",
            "tag": "important",
            "styles": null,
            "classes": null,
            "text": "This is `Dodisoft.Debug`, **not** `UnityEngine.Debug`. Use it exclusively for in-game script logging and control — do not mix with Unity's built-in debug tools."
        },
        {
            "id": "block-006",
            "tag": "tip",
            "styles": null,
            "classes": null,
            "text": "Call `Debug.Log(message)` to print values to the console while testing. Wrap logs in a condition or remove them before shipping."
        }
