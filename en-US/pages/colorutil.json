{
    "id": "colorutil",
    "lang": "en-US",
    "name": "ColorUtil",
    "description": "The `ColorUtil` library provides utilities for creating, converting, and decomposing `color` values.",
    "link": "/docs/uniscript/en-US/colorutil",
    "tags": [
        "uniscript",
        "colorutil"
    ],
    "previous": {
        "name": "RenderUtil",
        "link": "/docs/uniscript/en-US/renderutil"
    },
