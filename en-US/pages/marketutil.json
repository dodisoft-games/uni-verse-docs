{
    "id": "marketutil",
    "lang": "en-us",
    "name": "MarketUtil",
    "description": "Show an in-game store: open and close a product catalog and start a purchase, with results delivered back to your script.",
    "link": "/docs/uniscript/en-us/marketutil",
    "tags": [
        "uniscript",
        "marketutil",
        "store",
        "shop",
        "purchase",
        "catalog"
    ],
    "previous": {
        "name": "GameUtil",
        "link": "/docs/uniscript/en-us/gameutil"
    },
