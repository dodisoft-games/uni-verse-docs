{
    "id": "listutil",
    "lang": "en-us",
    "name": "ListUtil",
    "description": "Work with lists — ordered collections of values. Add, remove, count, look up by position, loop through, search, and sort.",
    "link": "/docs/uniscript/en-us/listutil",
    "tags": [
        "uniscript",
        "listutil",
        "list",
        "collection",
        "array"
    ],
    "previous": {
        "name": "QuaternionUtil",
        "link": "/docs/uniscript/en-us/quaternionutil"
    },
    "next": {
        "name": "DictionaryUtil",
        "link": "/docs/uniscript/en-us/dictionaryutil"
    },
    "content": [
        {
            "id": "block-001",
            "tag": "h1",
            "styles": null,
            "classes": null,
            "text": "ListUtil"
        },
        {
            "id": "block-002",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "A **list** is an ordered collection of values — like a shopping list. It can hold any number of items (enemies, scores, coin positions) and keeps them in order. `ListUtil` is how you add, remove, count, and look through those items."
        },
        {
            "id": "block-003",
            "tag": "important",
            "styles": null,
            "classes": null,
            "text": "Positions in a list start at **0**, not 1. The first item is at index `0`, the second at `1`, and so on. A list with 3 items has valid positions `0`, `1`, and `2`."
        },
        {
            "id": "block-004",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Creating a list and adding items"
        },
        {
            "id": "block-005",
            "tag": "code",
            "styles": null,
            "classes": null,
            "lines": [
                "// Make a new, empty list.",
                "List names = ListUtil.New();",
                "",
                "// Add items to the end.",
                "ListUtil.Add(names, \"Alice\");",
                "ListUtil.Add(names, \"Bob\");",
                "",
                "Debug.Log(ListUtil.Count(names));   // 2"
            ]
        },
        {
            "id": "block-006",
            "tag": "table",
            "styles": null,
            "classes": null,
            "headers": [
                "Method",
                "What it does"
            ],
            "rows": [
                ["`New()`", "Creates a new empty list."],
                ["`New(size)`", "Creates a list prepared to hold `size` items."],
                ["`Add(list, item)`", "Adds an item to the end."],
                ["`Insert(list, index, item)`", "Adds an item at a specific position, shifting the rest along."],
                ["`Count(list)`", "How many items the list currently holds."],
                ["`Clear(list)`", "Removes everything, leaving an empty list."]
            ]
        },
        {
            "id": "block-007",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Reading and changing items"
        },
        {
            "id": "block-008",
            "tag": "table",
            "styles": null,
            "classes": null,
            "headers": [
                "Method",
                "What it does"
            ],
            "rows": [
                ["`Get(list, index)`", "Reads the item at a position."],
                ["`Set(list, index, item)`", "Replaces the item at a position."],
                ["`First(list)` / `Last(list)`", "The first / last item — without needing to know the count."],
                ["`IndexOf(list, item)`", "The position of an item (or `-1` if it isn't in the list)."],
                ["`Contains(list, item)`", "`true` if the item is somewhere in the list."]
            ]
        },
        {
            "id": "block-009",
            "tag": "code",
            "styles": null,
            "classes": null,
            "lines": [
                "string first = ListUtil.Get(names, 0);   // \"Alice\"",
                "",
                "if (ListUtil.Contains(names, \"Bob\"))",
                "{",
                "    Debug.Log(\"Bob is on the list!\");",
                "}"
            ]
        },
        {
            "id": "block-010",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Removing items"
        },
        {
            "id": "block-011",
            "tag": "table",
            "styles": null,
            "classes": null,
            "headers": [
                "Method",
                "What it does"
            ],
            "rows": [
                ["`Remove(list, item)`", "Removes the first matching item. Returns `true` if something was removed."],
                ["`RemoveAt(list, index)`", "Removes the item at a specific position."]
            ]
        },
        {
            "id": "block-012",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Looping through a list"
        },
        {
            "id": "block-013",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "`ForEach` runs one of your methods once for every item in the list. You give it the list, `this`, the name of the method to run, and an extra value to pass along (use `null` if you don't need it). Your method receives each `item` and that extra `value`."
        },
        {
            "id": "block-014",
            "tag": "code",
            "styles": null,
            "classes": null,
            "lines": [
                "// Print every name in the list.",
                "ListUtil.ForEach(names, this, \"PrintName\", null);",
                "",
                "void PrintName(object item, object value)",
                "{",
                "    Debug.Log(\"Name: \" + item);",
                "}"
            ]
        },
        {
            "id": "block-015",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Searching and sorting"
        },
        {
            "id": "block-016",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "These also call one of your methods to decide what matches. The **filter** method receives `(item, value)` and returns `true` or `false`; the **sort** method receives two items and returns a number saying which comes first."
        },
        {
            "id": "block-017",
            "tag": "table",
            "styles": null,
            "classes": null,
            "headers": [
                "Method",
                "What it does"
            ],
            "rows": [
                ["`Find(list, this, method, value)`", "Returns the **first** item your filter approves."],
                ["`FindLast(list, this, method, value)`", "Returns the **last** item your filter approves."],
                ["`FindAll(list, this, method, value)`", "Returns a new list of **every** item your filter approves."],
                ["`Sort(list, this, method, value)`", "Reorders the list using your compare method."]
            ]
        },
        {
            "id": "block-018",
            "tag": "code",
            "styles": null,
            "classes": null,
            "lines": [
                "// Keep only the scores above a threshold.",
                "List winners = ListUtil.FindAll(scores, this, \"IsHigh\", 50);",
                "",
                "// Returns true for items that pass — those are kept.",
                "bool IsHigh(object item, object value)",
                "{",
                "    return item > value;   // value is 50 here",
                "}"
            ]
        },
        {
            "id": "block-019",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Full method reference"
        },
        {
            "id": "block-020",
            "tag": "table",
            "styles": null,
            "classes": null,
            "headers": [
                "Returns",
                "Method",
                "Parameters"
            ],
            "rows": [
                ["`List`", "`New`", "—"],
                ["`List`", "`New`", "`int size`"],
                ["`void`", "`Add`", "`List list, object item`"],
                ["`void`", "`Insert`", "`List list, int index, object item`"],
                ["`bool`", "`Remove`", "`List list, object item`"],
                ["`void`", "`RemoveAt`", "`List list, int index`"],
                ["`bool`", "`Contains`", "`List list, object item`"],
                ["`int`", "`Count`", "`List list`"],
                ["`void`", "`Clear`", "`List list`"],
                ["`object`", "`Get`", "`List list, int index`"],
                ["`object`", "`Set`", "`List list, int index, object item`"],
                ["`int`", "`IndexOf`", "`List list, object item`"],
                ["`object`", "`First`", "`List list`"],
                ["`object`", "`Last`", "`List list`"],
                ["`object`", "`Find`", "`List list, uniscript, string filterMethod, object filterValue`"],
                ["`object`", "`FindLast`", "`List list, uniscript, string filterMethod, object filterValue`"],
                ["`List`", "`FindAll`", "`List list, uniscript, string filterMethod, object filterValue`"],
                ["`bool`", "`Sort`", "`List list, uniscript, string sortMethod, object filterValue`"],
                ["`void`", "`ForEach`", "`List list, uniscript, string callMethod, object value`"]
            ]
        },
        {
            "id": "block-021",
            "tag": "tip",
            "styles": null,
            "classes": null,
            "text": "Need to store values by a name or key instead of a position (like player → score)? Use a [DictionaryUtil](/docs/uniscript/en-us/dictionaryutil) instead."
        }
    ]
}
