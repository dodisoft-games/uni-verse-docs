        {
            "id": "block-005",
            "tag": "note",
            "styles": null,
            "classes": null,
            "text": "Most methods require a `uniscript` reference as their first argument — pass the script instance that owns the physics body. Methods that operate on world coordinates (like `Raycast`) do not require this."
        },
        {
            "id": "block-006",
            "tag": "important",
            "styles": null,
            "classes": null,
            "text": "Always use `PhysicsUtil` to move physics-enabled objects. Setting `position` directly on an object with an active physics body causes undefined behaviour."
        },
        {
            "id": "block-007",
            "tag": "tip",
            "styles": null,
            "classes": null,
            "text": "Combine `SetVelocity` and `SetAngularVelocity` with a zero vector to stop an object instantly without applying forces."
        }
    ]
