{
    "id": "camerautil",
    "lang": "en-US",
    "name": "CameraUtil",
    "description": "The `CameraUtil` library provides access to the active camera and coordinate conversion utilities between 3D world space and 2D screen space.",
    "link": "/docs/uniscript/en-US/camerautil",
    "tags": [
        "uniscript",
        "camerautil"
    ],
    "previous": {
        "name": "PhysicsUtil",
        "link": "/docs/uniscript/en-US/physicsutil"
    },
