                ["`float`", "`Perlin3D`", "`float x, float y, float z`"]
            ]
        },
        {
            "id": "block-036",
            "tag": "tip",
            "styles": null,
            "classes": null,
            "text": "Working with positions and directions instead of single numbers? See [VectorUtil](/docs/uniscript/en-us/vectorutil) for the 3D version of these tools."
        }
    ]
}
