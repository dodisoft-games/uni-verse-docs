        {
            "id": "block-005",
            "tag": "note",
            "styles": null,
            "classes": null,
            "text": "`PI()`, `Deg2Rad()`, `Rad2Deg()`, `Epsilon()`, `Infinity()`, and `NegativeInfinity()` are methods with no parameters — they return their respective constant values."
        },
        {
            "id": "block-006",
            "tag": "tip",
            "styles": null,
            "classes": null,
            "text": "Use `Math.Lerp(a, b, t)` to smoothly interpolate between two values over time. `t` should be between `0` and `1`. For clamped results use `Math.Clamp01(t)` before passing it."
        },
        {
            "id": "block-007",
            "tag": "tip",
            "styles": null,
            "classes": null,
            "text": "Use `Math.Random(min, max)` to generate random integers or floats. Call `Math.InitSeed(seed)` first if you need reproducible results."
        }
