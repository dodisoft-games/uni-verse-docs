{
    "id": "quaternionutil",
    "lang": "en-US",
    "name": "QuaternionUtil",
    "description": "The `QuaternionUtil` library provides rotation utilities using quaternions — the standard representation for 3D rotations that avoids gimbal lock.",
    "link": "/docs/uniscript/en-US/quaternionutil",
    "tags": [
        "uniscript",
        "quaternionutil"
    ],
    "previous": {
        "name": "VectorUtil",
        "link": "/docs/uniscript/en-US/vectorutil"
