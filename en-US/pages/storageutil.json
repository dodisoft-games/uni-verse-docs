        {
            "id": "block-005",
            "tag": "note",
            "styles": null,
            "classes": null,
            "text": "Storage is persistent across sessions (PlayerPrefs-style). Keys are global — use a consistent naming convention to avoid collisions between scripts."
        },
        {
            "id": "block-006",
            "tag": "tip",
            "styles": null,
            "classes": null,
            "text": "Use `StorageUtil.HasKey(key)` before reading a value to avoid unexpected defaults on a fresh install."
