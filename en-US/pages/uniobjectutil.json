        {
            "id": "block-005",
            "tag": "note",
            "styles": null,
            "classes": null,
            "text": "This is the most-used library in UniScript. `GetUniObject(uniscript)` retrieves the object that owns the calling script — use it as the entry point for most transform and lifecycle operations."
        },
        {
            "id": "block-006",
            "tag": "tip",
            "styles": null,
            "classes": null,
            "text": "Prefer `FindUniObjectsByTag` over `FindUniObjectsByName` for better performance when searching the scene."
