    "content": [
        {
            "id": "block-001",
            "tag": "h1",
            "styles": null,
            "classes": null,
            "text": "GameUtil"
        },
        {
            "id": "block-002",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "`GameUtil` provides a ready-made game-building helper: turning an object into a **moving platform**. A moving platform carries whatever stands on it — so when the platform slides or rises, the player rides along instead of being left behind."
        },
        {
            "id": "block-003",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Making a moving platform"
        },
        {
            "id": "block-004",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "Call `AddMovingPlatform(this)` once on the object. After that, move the platform however you like — players standing on it move with it correctly."
        },
        {
            "id": "block-005",
            "tag": "code",
            "styles": null,
            "classes": null,
            "lines": [
                "class Elevator",
                "{",
                "    void OnInit()",
                "    {",
                "        GameUtil.AddMovingPlatform(this);",
                "    }",
                "",
                "    void OnUpdate()",
                "    {",
                "        // Bob the platform up and down; riders move with it.",
                "        float y = Math.Sin(Time.GameTime()) * 2.0;",
                "        UniObjectUtil.SetPosition(this, VectorUtil.New(0.0, y, 0.0));",
                "    }",
                "}"
            ]
        },
        {
            "id": "block-006",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Full method reference"
        },
        {
            "id": "block-007",
            "tag": "table",
            "styles": null,
            "classes": null,
            "headers": [
                "Returns",
                "Method",
                "Parameters"
            ],
            "rows": [
                ["`void`", "`AddMovingPlatform`", "`uniscript`"]
            ]
        },
        {
            "id": "block-008",
            "tag": "tip",
            "styles": null,
            "classes": null,
            "text": "Move the platform with [UniObjectUtil](/docs/uniscript/en-US/uniobjectutil#block-004) for simple back-and-forth motion, or drive it with physics from [PhysicsUtil](/docs/uniscript/en-US/physicsutil) — either way, `AddMovingPlatform` is what makes riders stick."
        }
    ]
}
