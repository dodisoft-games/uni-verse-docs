{
    "id": "typeutil",
    "lang": "en-US",
    "name": "TypeUtil",
    "description": "The `TypeUtil` library provides runtime type inspection and conversion utilities.",
    "link": "/docs/uniscript/en-US/typeutil",
    "tags": [
        "uniscript",
        "typeutil"
    ],
