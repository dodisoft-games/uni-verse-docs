{
    "id": "dictionaryutil",
    "lang": "en-US",
    "name": "DictionaryUtil",
    "description": "The `DictionaryUtil` library provides static helper operations for Uniscript's native `dictionary` type, which does not support direct method calls.",
    "link": "/docs/uniscript/en-US/dictionaryutil",
    "tags": [
        "uniscript",
        "dictionaryutil"
    ],
