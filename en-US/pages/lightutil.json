{
    "id": "lightutil",
    "lang": "en-US",
    "name": "LightUtil",
    "description": "The `LightUtil` library manages light source registration and runtime adjustment of both individual lights and the global scene lighting.",
    "link": "/docs/uniscript/en-US/lightutil",
    "tags": [
        "uniscript",
        "lightutil"
    ],
