    "content": [
        {
            "id": "block-001",
            "tag": "h1",
            "styles": null,
            "classes": null,
            "text": "LightUtil"
        },
        {
            "id": "block-002",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "The `LightUtil` library manages light source registration and runtime adjustment of both individual lights and the global scene lighting. Use it from light component scripts to register with the lighting system, and to modify ambient or directional light at runtime for dynamic time-of-day or mood effects."
        },
        {
            "id": "block-003",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Namespace"
        },
        {
            "id": "block-004",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "Available as `Universe.Core`."
        },
        {
            "id": "block-005",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Light Registration"
        },
        {
            "id": "block-006",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "Register a light component with the lighting system from `OnInit`."
        },
        {
            "id": "block-007",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "Registers `script`'s host object as a light source. Must be called from `OnInit` of a light script."
        },
        {
            "id": "block-008",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Runtime Light Control"
        },
        {
            "id": "block-009",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "Adjust individual light properties at runtime."
        },
        {
            "id": "block-010",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "Sets the brightness of the light registered on `script`."
        },
        {
            "id": "block-011",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "Sets the maximum distance the light reaches."
        },
        {
            "id": "block-012",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "Sets the RGBA colour of the light."
        },
        {
            "id": "block-013",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "Enables or disables the light registered on `script`."
        },
        {
            "id": "block-014",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Global / Ambient Lighting"
        },
        {
            "id": "block-015",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "Adjust scene-wide lighting settings."
        },
        {
            "id": "block-016",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "Sets the ambient light colour that illuminates surfaces not directly lit by any light source."
        },
        {
            "id": "block-017",
            "tag": "p",
            "styles": null,
            "classes": null,
            "text": "Adjusts the primary directional light (sunlight) colour and intensity."
        },
        {
            "id": "block-018",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Notes"
        },
        {
            "id": "block-019",
            "tag": "note",
            "styles": null,
            "classes": null,
            "text": "Every light script must call `LightUtil.AddLight(this)` in `OnInit` — without registration, the object emits no light at runtime."
        },
        {
            "id": "block-020",
            "tag": "note",
            "styles": null,
            "classes": null,
            "text": "Changing `SetAmbientLight` affects the entire scene globally. Coordinate this from a single scene-management script to avoid conflicts."
        },
        {
            "id": "block-021",
            "tag": "h2",
            "styles": null,
            "classes": null,
            "text": "Example Usage"
        },
        {
            "id": "block-022",
            "tag": "code",
            "styles": null,
            "classes": null,
            "lines": [
                "// Register a light in OnInit",
                "void OnInit() {",
                "    LightUtil.AddLight(this);",
                "}",
                "",
                "// Flicker effect — randomly vary intensity each frame",
                "void OnUpdate() {",
                "    float flicker = 0.8 + Math.Random(0.0, 0.4);",
                "    LightUtil.SetIntensity(this, flicker);",
                "}",
                "",
                "// Day/night cycle — shift ambient colour over time",
                "float t = Math.Clamp01(dayProgress);",
                "color dayAmbient   = ColorUtil.FromRGBA(0.9, 0.9, 1.0, 1.0);",
                "color nightAmbient = ColorUtil.FromRGBA(0.05, 0.05, 0.2, 1.0);",
                "LightUtil.SetAmbientLight(ambientLerped);"
            ]
        }
    ]
}